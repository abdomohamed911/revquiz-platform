# ─── Server Environment Variables ───
# Database (use MONGODB_URI for Atlas, or DB_URL+DB_NAME for local)
MONGODB_URI=mongodb+srv://user:password@cluster.xxxxx.mongodb.net/revquiz
DB_URL=mongodb://localhost:27017
DB_NAME=revquiz

# Authentication
JWT_SECRET=your-32-character-random-secret-here

# CORS (comma-separated origins; omit for development wildcard)
CORS_ORIGIN=https://revquiz-platform.vercel.app

# Server
NODE_ENV=production
PORT=5000

# Seed key (only needed when calling POST /seed)
SEED_KEY=your-random-seed-key
